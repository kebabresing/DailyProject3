<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .font-outfit { font-family: 'Outfit', sans-serif; }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="text-slate-700 bg-gradient-to-br from-slate-50 via-white to-indigo-50/50 flex flex-col min-h-screen selection:bg-indigo-500/30">
    <nav class="bg-white/70 backdrop-blur-xl border-b border-white/40 shadow-sm w-full sticky top-0 z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center group cursor-pointer">
                    <a href="/">
                        <img src="/logo.png" alt="Alumni Tracker Logo" class="h-16 w-auto group-hover:scale-105 transition-transform duration-300">
                    </a>
                </div>
                <!-- Navigation Links -->
                <div class="hidden sm:flex space-x-1">
                    <a href="/" class="text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/50 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300">Laporan Statistik</a>
                    <a href="/data" class="text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/50 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300">Data Master</a>
                </div>
                <!-- Mobile Navigation (Simple fallback for demo) -->
                <div class="flex sm:hidden space-x-2">
                     <a href="/" class="text-indigo-600 text-sm font-semibold bg-indigo-50 px-3 py-1.5 rounded-lg">Laporan</a>
                     <a href="/data" class="text-indigo-600 text-sm font-semibold bg-indigo-50 px-3 py-1.5 rounded-lg">Data</a>
                </div>
            </div>
        </div>
    </nav>
    <main class="flex-grow w-full max-w-7xl mx-auto">
